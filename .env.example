# MongoDB connection string (required)
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/statuspulse?retryWrites=true&w=majority"

# Auth.js (next-auth v5) — required for OAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

# AI Chat Assistant (DeepSeek V4 Pro)
# Production: Set in EdgeOne/Vercel dashboard as "sensitive" (encrypted at rest)
# Local dev: Set in .env (gitignored, never commit)
AI_GATEWAY_API_KEY="sk-your-deepseek-key"
AI_GATEWAY_BASE_URL="https://api.deepseek.com/v1"
AI_GATEWAY_MODEL="deepseek-v4-pro"

# Key Rotation: Set this during rotation window, then remove after deploy
# Never commit real keys. Rotate every 30-90 days.
# AI_GATEWAY_API_KEY_FALLBACK="sk-your-new-key-during-rotation"

# Tavily Web Search
# Production: Set in platform dashboard (encrypted)
TAVILY_API_KEY="tvly-your-tavily-key"
# TAVILY_API_KEY_FALLBACK="tvly-your-new-key-during-rotation"

# Dev keys (local development only — .env is gitignored)
# DEEPSEEK_DEV_KEY="sk-dev-key"
# TAVILY_DEV_KEY="tvly-dev-key"

# Optional
REDIS_URL="redis://localhost:6379"
SCHEDULER_INTERVAL="20000"
LOG_LEVEL="info"
NEXT_PUBLIC_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"
